{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#merchant",
      "@type": "Restaurant",
      "name": "PREM BED"
    },
    {
      "@id": "#order",
      "@type": "Order",
      "seller": { "@id": "#merchant" },
      "priceCurrency": "USD",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "acceptedOffer": [
        { "@id": "#offer-1" },
        { "@id": "#offer-2" },
        { "@id": "#offer-3" }
      ],
      "additionalProperty": [
        { "@type": "PropertyValue", "name": "Item", "value": "Parmzi" },
        { "@type": "PropertyValue", "name": "Item", "value": "TENG vane" },
        { "@type": "PropertyValue", "name": "Subtotal", "unitText": "USD", "value": "132.25" },
        { "@type": "PropertyValue", "name": "Tax", "value": "3%" }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "37.78",
      "priceCurrency": "USD",
      "itemOffered": { "@id": "#item-1" }
    },
    { "@id": "#item-1", "@type": "MenuItem", "name": "Parmzi" },
    {
      "@id": "#offer-2",
      "@type": "Offer",
      "price": "23.70",
      "priceCurrency": "USD",
      "itemOffered": { "@id": "#item-2" }
    },
    { "@id": "#item-2", "@type": "MenuItem", "name": "TENG" },
    {
      "@id": "#offer-3",
      "@type": "Offer",
      "price": "78.00",
      "priceCurrency": "USD",
      "itemOffered": { "@id": "#item-3" }
    },
    { "@id": "#item-3", "@type": "MenuItem", "name": "Beer" }
  ]
}
