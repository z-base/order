{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#merchant",
      "@type": "Restaurant",
      "name": "TRG"
    },
    {
      "@id": "#order",
      "@type": "Order",
      "seller": { "@id": "#merchant" },
      "priceCurrency": "USD",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "acceptedOffer": [
        { "@id": "#offer-1" },
        { "@id": "#offer-2" },
        { "@id": "#offer-3" },
        { "@id": "#offer-4" }
      ],
      "additionalProperty": [
        { "@type": "PropertyValue", "name": "Naf Abe", "value": "4.70" },
        { "@type": "PropertyValue", "name": "Butts Moog", "value": "7.00" },
        { "@type": "PropertyValue", "name": "Cate Sto", "value": "4.75" },
        { "@type": "PropertyValue", "name": "Man Hap Tacy", "value": "15.09" },
        { "@type": "PropertyValue", "name": "Subtotal", "unitText": "USD", "value": "37.60" }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-1" }
    },
    { "@id": "#item-1", "@type": "MenuItem", "name": "Naf Abe" },
    {
      "@id": "#offer-2",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-2" }
    },
    { "@id": "#item-2", "@type": "MenuItem", "name": "Butts Moog" },
    {
      "@id": "#offer-3",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-3" }
    },
    { "@id": "#item-3", "@type": "MenuItem", "name": "Cate Sto" },
    {
      "@id": "#offer-4",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-4" }
    },
    { "@id": "#item-4", "@type": "MenuItem", "name": "Man Hap Tacy" }
  ]
}
