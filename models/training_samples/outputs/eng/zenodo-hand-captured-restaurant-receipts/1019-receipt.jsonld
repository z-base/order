{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#merchant",
      "@type": "Restaurant",
      "name": "OT PIERI"
    },
    {
      "@id": "#order",
      "@type": "Order",
      "seller": { "@id": "#merchant" },
      "orderDate": "2017-12-05T19:48:12",
      "priceCurrency": "USD",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "acceptedOffer": [
        { "@id": "#offer-1" },
        { "@id": "#offer-2" },
        { "@id": "#offer-3" }
      ],
      "additionalProperty": [
        { "@type": "PropertyValue", "name": "SubTotal", "unitText": "USD", "value": "8.00" },
        { "@type": "PropertyValue", "name": "Tax", "unitText": "USD", "value": "0.25" }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-1" }
    },
    { "@id": "#item-1", "@type": "MenuItem", "name": "Cheese Break" },
    {
      "@id": "#offer-2",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-2" }
    },
    { "@id": "#item-2", "@type": "MenuItem", "name": "Pepper Rings" },
    {
      "@id": "#offer-3",
      "@type": "Offer",
      "itemOffered": { "@id": "#item-3" }
    },
    { "@id": "#item-3", "@type": "MenuItem", "name": "Regular Margherita" }
  ]
}
