{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#merchant",
      "@type": "Restaurant",
      "name": "CANOGA PARK",
      "address": { "@type": "PostalAddress", "streetAddress": "717", "postalCode": "6185760190" }
    },
    {
      "@id": "#order",
      "@type": "Order",
      "seller": { "@id": "#merchant" },
      "priceCurrency": "USD",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "additionalProperty": [
        { "@type": "PropertyValue", "name": "Tax", "unitText": "USD", "value": "5.80" },
        { "@type": "PropertyValue", "name": "Tax Rate", "value": "5.8" },
        { "@type": "PropertyValue", "name": "Total", "unitText": "USD", "value": "10.94" }
      ]
    }
  ]
}
