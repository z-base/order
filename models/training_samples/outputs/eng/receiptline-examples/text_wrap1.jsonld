{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#order",
      "@type": "Order",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "3.90",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#item-1"
      }
    },
    {
      "@id": "#item-1",
      "@type": "MenuItem",
      "name": "Hamburger w/ tomato, onion, meat sauce, mayonnaise, mustard"
    }
  ]
}
