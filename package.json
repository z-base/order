{
  "name": "@z-base/package-name",
  "version": "0.0.0",
  "description": "",
  "keywords": [
    "typescript",
    "z-base"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/<entity>/<package-name>.git"
  },
  "bugs": {
    "url": "https://github.com/<entity>/<package-name>/issues"
  },
  "homepage": "https://z-base.github.io/<package-name>",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "countSamples": "node models/scripts/.helpers/get-outputs-sample-count.mjs",
    "download:receipt-images": "node models/scripts/data/download-receipt-images.mjs",
    "download:receipt-pdfs": "node models/scripts/data/download-receipt-pdfs.mjs",
    "download:receipt-texts": "node models/scripts/data/download-receipt-texts.mjs",
    "download:receipts": "npm run download:receipt-images && npm run download:receipt-pdfs && npm run download:receipt-texts",
    "extract:receipt-images": "node models/scripts/data/extract-inputs-from-receipt-images.mjs",
    "extract:receipt-pdfs": "node models/scripts/data/extract-inputs-from-receipt-pdfs.mjs",
    "extract:receipt-texts": "node models/scripts/data/extract-inputs-from-receipt-texts.mjs",
    "extract:inputs": "node models/scripts/data/extract-inputs.mjs",
    "corpus:build": "node models/scripts/data/transform-samples-to-corpus.mjs",
    "tokenizer:train": "python models/scripts/data/train_tokenizer_vocabs.py",
    "dataset:build": "node models/scripts/data/transform-corpus-to-tokenized-dataset.mjs",
    "train:overfit": "python models/scripts/overfit/train_seq2seq_overfit.py",
    "export:onnx": "python models/scripts/production/export_best_model_to_onnx.py",
    "quantize:onnx": "python models/scripts/production/quantize_onnx_models_to_4bit.py",
    "pipeline:data": "node models/scripts/data/run-pipeline.mjs",
    "pipeline:overfit": "python models/scripts/overfit/train_seq2seq_overfit.py",
    "pipeline:production": "node models/scripts/production/run-pipeline.mjs",
    "format": "prettier . --write",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "c8": "^11.0.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@adobe/structured-data-validator": "^1.7.0",
    "@sctg/sentencepiece-js": "^1.3.3",
    "@z-base/bytecodec": "^1.1.0",
    "@z-base/cryptosuite": "^1.0.1",
    "@z-base/zero-knowledge-credentials": "^1.0.2",
    "franc": "^6.2.0",
    "onnxruntime-web": "^1.24.3",
    "pdfjs-dist": "^5.5.207",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "unzipper": "^0.12.3"
  }
}
