{
  "name": "@z-base/package-name",
  "version": "0.0.0",
  "description": "",
  "keywords": [
    "typescript",
    "z-base"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/<entity>/<package-name>.git"
  },
  "bugs": {
    "url": "https://github.com/<entity>/<package-name>/issues"
  },
  "homepage": "https://z-base.github.io/<package-name>",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "download:receipts": "node scripts/download-receipts.mjs",
    "format": "prettier . --write",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "c8": "^11.0.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@agnai/sentencepiece-js": "^1.1.1",
    "@z-base/bytecodec": "^1.1.0",
    "@z-base/cryptosuite": "^1.0.1",
    "@z-base/zero-knowledge-credentials": "^1.0.2",
    "franc": "^6.2.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  }
}
